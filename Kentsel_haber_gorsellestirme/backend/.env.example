# ─── Google APIs ──────────────────────────────────────
# Google Cloud Console'dan Maps JavaScript API ve Geocoding API
# etkinleştirildikten sonra alınan API anahtarı
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key_here

# ─── MongoDB ──────────────────────────────────────────
# MongoDB Atlas connection string veya lokal MongoDB URI
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=KentselHaberIzleme
MONGO_DB_NAME=kocaeli_haberler
